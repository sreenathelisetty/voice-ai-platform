# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ── Whisper ───────────────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=small.en          # tiny, base, small, medium, large
WHISPER_DEVICE=cpu                   # cpu or cuda
WHISPER_MODEL_DIR=/app/models/whisper

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_MODEL_NAME=tts_models/en/ljspeech/fast_pitch
TTS_MODEL_DIR=/app/models/tts
TTS_SAMPLE_RATE=22050
TTS_OUTPUT_SAMPLE_RATE=24000

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_INPUT_SAMPLE_RATE=16000        # PCM from client
AUDIO_CHUNK_DURATION_MS=100          # chunk size streaming from client
VAD_AGGRESSIVENESS=2                 # 0-3 (3 = most aggressive)
VAD_SILENCE_THRESHOLD_MS=800         # silence before utterance is complete
OPUS_BITRATE=64000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=1800       # 30 minutes idle
REDIS_RECONNECT_WINDOW_SECONDS=60
REDIS_MAX_HISTORY_TURNS=20

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://voice:voice@localhost:5432/voiceai
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production
API_TOKEN=dev-token                  # WebSocket auth token

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_CLOUDWATCH_LOG_GROUP=/voice-ai/backend

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | console
